local touchSens = 0.6
local camRotX, camRotY = 0, 0
local touchLookActive = false 

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        if not gameProcessed and isFreeCamEnabled then
            touchLookActive = true
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        touchLookActive = false
    end
end)

UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
        if isFreeCamEnabled and touchLookActive then
            local delta = input.Delta
            camRotX = camRotX - math.rad(delta.Y * touchSens)
            camRotY = camRotY - math.rad(delta.X * touchSens)
        end
    end
end)

