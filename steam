-- Main Logic
toggleFreeCam = function()
    isFreeCamEnabled = not isFreeCamEnabled
    if isFreeCamEnabled then
        if spectatingPlayer then
            spectatingPlayer = nil
            spectateFrame.Visible = false
            camera.CameraSubject = localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") or nil
        end
        
        freeCamButton.Text = isMobile and "📷 กล้อง: เปิด" or "📷 กล้อง: เปิด (Z)"
        freeCamButton.UIStroke.Color = Color3.fromRGB(255, 100, 255)
        camera.CameraType = Enum.CameraType.Scriptable
        
        if isMobile then
            mobileCamFrame.Visible = true
            local rx, ry, rz = camera.CFrame:ToEulerAnglesYXZ()
            camRotX, camRotY = rx, ry
        end
        
        if Controls then Controls:Disable() end
        resetButton.Visible = true
    else
        freeCamButton.Text = isMobile and "📷 กล้อง: ปิด" or "📷 กล้อง: ปิด (Z)"
        freeCamButton.UIStroke.Color = THEME_FREECAM
        camera.CameraType = Enum.CameraType.Custom
        
        if isMobile then
            mobileCamFrame.Visible = false
        end
        
        if Controls then Controls:Enable() end
        resetButton.Visible = false
    end
end

