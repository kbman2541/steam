local function checkFriendStatus(player)
    if player == localPlayer then return end
    task.spawn(function()
        -- เช็คบล็อกก่อน
        local isBlocked = false
        local s2, blockedList = pcall(function() return StarterGui:GetCore("GetBlockedUserIds") end)
        if s2 and blockedList then
            for _, id in ipairs(blockedList) do
                if id == player.UserId then isBlocked = true; break end
            end
        end
        blockedStatus[player.UserId] = isBlocked
        
        -- ถ้าบล็อก = ไม่ใช่เพื่อนแน่นอน
        if isBlocked then
            friendStatus[player.UserId] = false
        else
            -- ถ้าไม่ได้บล็อก ให้เช็คว่าเป็นเพื่อนไหม
            local success, isFriend = pcall(function()
                return localPlayer:IsFriendsWith(player.UserId)
            end)
            if success then
                friendStatus[player.UserId] = isFriend
            else
                friendStatus[player.UserId] = false -- ถ้าเช็คไม่ได้ ให้ตีเป็นไม่ใช่เพื่อนไว้ก่อน
            end
        end
    end)
end

task.spawn(function()
    while true do
        task.wait(3)
        local blockedList = {}
        local sBlock, bResult = pcall(function() return StarterGui:GetCore("GetBlockedUserIds") end)
        if sBlock then blockedList = bResult end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                local pid = player.UserId
                local isBlocked = false
                for _, id in ipairs(blockedList) do
                    if id == pid then isBlocked = true; break end
                end
                blockedStatus[pid] = isBlocked
                
                if isBlocked then
                    friendStatus[pid] = false
                else
                    local sFriend, isFriend = pcall(function() return localPlayer:IsFriendsWith(pid) end)
                    if sFriend then
                        friendStatus[pid] = isFriend
                    end
                end
            end
        end
    end
end)

for _, player in ipairs(Players:GetPlayers()) do
    checkFriendStatus(player)
end

