updatePlayerList = function()
    for _, child in pairs(listFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local searchText = string.lower(searchBox.Text)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if searchText == "" or string.find(string.lower(player.Name), searchText) then
            local entry = Instance.new("TextButton")
            entry.Size = UDim2.new(1, -4, 0, 40) -- ใหญ่ขึ้นนิดให้นิ้วจิ้มง่าย
            entry.BackgroundColor3 = THEME_PURPLE
            entry.BackgroundTransparency = 0.5
            entry.Text = ""
            entry.Parent = listFrame
            
            local uic = Instance.new("UICorner", entry); uic.CornerRadius = UDim.new(0,6)
            
            local txt = Instance.new("TextLabel", entry)
            txt.Size = UDim2.new(1, -10, 1, 0)
            txt.Position = UDim2.new(0, 10, 0, 0)
            txt.BackgroundTransparency = 1
            txt.TextColor3 = THEME_WHITE
            txt.TextXAlignment = Enum.TextXAlignment.Left
            txt.Text = player.DisplayName
            txt.Font = Enum.Font.GothamMedium
            txt.TextSize = 14

            entry.MouseButton1Click:Connect(function()
                if player.Character and player.Character:FindFirstChild("Humanoid") then
                     camera.CameraSubject = player.Character.Humanoid
                     spectatingPlayer = player
                     resetButton.Visible = true
                end
            end)
        end
    end
end
