local function bindButton(btn, callback)
    local db = false
    local function action()
        if db then return end
        db = true
        print("Button " .. btn.Name .. " Pressed")
        callback()
        task.wait(0.2)
        db = false
    end
    btn.Activated:Connect(action)
    btn.MouseButton1Click:Connect(action)
end

