local function ensureMyFriends()
    if myFriendsCache then return end
    task.spawn(function()
        local friends = {}
        local success, pages = pcall(function() return Players:GetFriendsAsync(localPlayer.UserId) end)
        if success then
            while true do
                for _, item in ipairs(pages:GetCurrentPage()) do friends[item.Id] = true end
                if pages.IsFinished then break end
                pages:AdvanceToNextPageAsync()
            end
            myFriendsCache = friends
        end
    end)
end
ensureMyFriends()

local function makeDraggable(frame)
    frame.Active = true 
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input) if input == dragInput and dragging then update(input) end end)
end

local function checkFriendStatus(player)
    if player == localPlayer then return end
    task.spawn(function()
        local isBlocked = false
        local s2, blockedList = pcall(function() return StarterGui:GetCore("GetBlockedUserIds") end)
        if s2 and blockedList then
            for _, id in ipairs(blockedList) do if id == player.UserId then isBlocked = true; break end end
        end
        blockedStatus[player.UserId] = isBlocked
        if isBlocked then friendStatus[player.UserId] = false
        else
            local s, f = pcall(function() return localPlayer:IsFriendsWith(player.UserId) end)
            if s then friendStatus[player.UserId] = f else friendStatus[player.UserId] = false end
        end
    end)
end

