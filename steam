-- FreeCam Toggle Logic
local function toggleFreeCam()
    isFreeCamEnabled = not isFreeCamEnabled
    if isFreeCamEnabled then
        freeCamButton.Text = isMobile and "📷 กล้อง: เปิด" or "📷 กล้อง: เปิด (Z)"
        freeCamButton.UIStroke.Color = Color3.fromRGB(255, 100, 255)
        camera.CameraType = Enum.CameraType.Scriptable
        if Controls then Controls:Disable() end
        resetButton.Visible = true
        
        -- Add Mobile Touch Drag for Camera here if needed
    else
        freeCamButton.Text = isMobile and "📷 กล้อง: ปิด" or "📷 กล้อง: ปิด (Z)"
        freeCamButton.UIStroke.Color = THEME_FREECAM
        camera.CameraType = Enum.CameraType.Custom
        if Controls then Controls:Enable() end
        resetButton.Visible = false
    end
end
freeCamButton.MouseButton1Click:Connect(toggleFreeCam)

