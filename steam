showMutualFriends = function(targetPlayer)
    if not targetPlayer then return end
    mutualFrame.Visible = true
    for _,c in pairs(mfList:GetChildren()) do if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end end
    
    local loading = Instance.new("TextLabel", mfList); loading.Text = "Scanning..."; loading.Size = UDim2.new(1,0,0,30); loading.TextColor3 = THEME_SELECTED; loading.BackgroundTransparency = 1
    
    task.spawn(function()
        ensureMyFriends()
        
        local mutuals = {}
        local targetFriends = {}
        local s, pages = pcall(function() return Players:GetFriendsAsync(targetPlayer.UserId) end)
        
        if s then
            while true do
                for _, item in ipairs(pages:GetCurrentPage()) do table.insert(targetFriends, item) end
                if pages.IsFinished then break end
                pages:AdvanceToNextPageAsync()
            end
        else
            loading.Text = "Profile is Private"
            return
        end
        
        for _, f in ipairs(targetFriends) do
            if myFriendsCache and myFriendsCache[f.Id] then table.insert(mutuals, f) end
        end
        
        if loading then loading:Destroy() end
        
        local function addHeader(text)
            local h = Instance.new("TextLabel", mfList); h.Text = text; h.Size = UDim2.new(1,0,0,25); h.TextColor3 = THEME_MAIN; h.BackgroundTransparency = 1; h.Font = Enum.Font.GothamBold; h.TextXAlignment = Enum.TextXAlignment.Left; h.ZIndex = 22
        end
        
        addHeader("Mutual Friends ("..#mutuals..")")
        for _, m in ipairs(mutuals) do
            local btn = Instance.new("TextButton", mfList); btn.Text = m.Username; btn.Size = UDim2.new(1,0,0,30); btn.BackgroundColor3 = Color3.fromRGB(40,40,50); btn.TextColor3 = THEME_WHITE; btn.ZIndex = 22
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
        end
        
        -- Friends in Server
        local serverFriends = {}
        for _, p in ipairs(Players:GetPlayers()) do
             for _, tf in ipairs(targetFriends) do
                 if p.UserId == tf.Id then table.insert(serverFriends, p) end
             end
        end
        
        addHeader("Friends in Server ("..#serverFriends..")")
        for _, p in ipairs(serverFriends) do
