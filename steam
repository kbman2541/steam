    espButton.UIStroke.Color = isEspEnabled and THEME_MAIN or Color3.fromRGB(200, 60, 60)
    if not isEspEnabled then clearAllESP() end
end)

-- Keyboard Input (PC Only)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Z then toggleFreeCam() end
    if input.KeyCode == Enum.KeyCode.X then 
        isEspEnabled = not isEspEnabled
        if not isEspEnabled then clearAllESP() end
    end
end)

-- ESP Loop
RunService.RenderStepped:Connect(function(dt)
    -- FreeCam Move Logic (PC Only - Mobile relies on Spectate)
    if isFreeCamEnabled and not isMobile then
        local move = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0,0,-1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1,0,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1,0,0) end
        camera.CFrame = camera.CFrame * CFrame.new(move * 60 * dt)
    end
    
    if isEspEnabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer and player.Character and player.Character:FindFirstChild("Head") then
                local head = player.Character.Head
                -- ESP Creation Logic (Simplified)
                local bb = nameplates[player]
                if not bb or bb.Adornee ~= head then
                    if bb then bb:Destroy() end
                    bb = Instance.new("BillboardGui", espFolder)
                    bb.Name = "ESP"
                    bb.Adornee = head
                    bb.Size = UDim2.new(0,100,0,50); bb.StudsOffset = Vector3.new(0,3,0); bb.AlwaysOnTop=true
                    
                    local txt = Instance.new("TextLabel", bb)
                    txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency=1; txt.TextColor3=THEME_MAIN; txt.Text=player.DisplayName
                    txt.TextStrokeTransparency=0.5
                    
                    local btn = Instance.new("TextButton", bb) -- Touch to spectate
                    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency=1; btn.Text=""
                    btn.MouseButton1Click:Connect(function()
                        camera.CameraSubject = player.Character.Humanoid
                        spectatingPlayer = player
                        resetButton.Visible = true
                    end)
                    
                    nameplates[player] = bb
                end
                
                -- Update Highlight
                local hl = player.Character:FindFirstChild("FantasyHighlight")
                if not hl then
                    hl = Instance.new("Highlight", player.Character)
                    hl.Name = "FantasyHighlight"
                    hl.FillTransparency = 0.5
                end
                
                -- Check Friend/Enemy color
                local color = COLOR_ENEMY
                if friendStatus[player.UserId] then color = THEME_MAIN end
                if blockedStatus[player.UserId] then color = COLOR_BLOCKED_USER end
                
                hl.FillColor = color
                hl.OutlineColor = color
                if nameplates[player] and nameplates[player]:FindFirstChild("TextLabel") then
                    nameplates[player].TextLabel.TextColor3 = color
                end
            end
        end
    end
end)

