local nameplates = {}
local function clearAllESP()
    espFolder:ClearAllChildren()
    table.clear(nameplates)
    for _, p in ipairs(Players:GetPlayers()) do if p.Character then local h = p.Character:FindFirstChild("FantasyHighlight"); if h then h:Destroy() end end end
end

updatePlayerList = function()
    for _,c in pairs(listFrame:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    local txt = string.lower(searchBox.Text)
    for _, p in ipairs(Players:GetPlayers()) do
        if txt=="" or string.find(string.lower(p.Name), txt) then
            local row = Instance.new("Frame", listFrame)
            row.Size = UDim2.new(1, -4, 0, 45)
            row.BackgroundColor3 = THEME_PURPLE
            row.BackgroundTransparency = 0.5
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

            local specBtn = Instance.new("TextButton", row)
            specBtn.Size = UDim2.new(1, -80, 1, 0)
            specBtn.BackgroundTransparency = 1
            specBtn.Text = ""
            specBtn.ZIndex = 2
            
            local nm = Instance.new("TextLabel", row)
            nm.Size = UDim2.new(1, -80, 1, 0)
            nm.Position = UDim2.new(0, 10, 0, 0)
            nm.BackgroundTransparency = 1
            nm.Text = p.DisplayName
            nm.TextColor3 = THEME_WHITE
            nm.Font = Enum.Font.GothamMedium
            nm.TextSize = 14
            nm.TextXAlignment = Enum.TextXAlignment.Left
            nm.ZIndex = 2

            bindButton(specBtn, function() 
                if p.Character and p.Character:FindFirstChild("Humanoid") then
                    if isFreeCamEnabled then
                        isFreeCamEnabled = false
                        mobileCamFrame.Visible = false
                        freeCamButton.Text = isMobile and "📷 กล้อง: ปิด" or "📷 กล้อง: ปิด (Z)"
                        freeCamButton.UIStroke.Color = THEME_FREECAM
                    end
                    camera.CameraType = Enum.CameraType.Custom
                    camera.CameraSubject = p.Character.Humanoid
                    spectatingPlayer = p
                    if Controls then Controls:Disable() end
                    resetButton.Visible = true 
                end 
            end)

            if p ~= localPlayer then
                local mfBtn = Instance.new("TextButton", row)
                mfBtn.Size = UDim2.new(0, 30, 0, 30)
                mfBtn.Position = UDim2.new(1, -75, 0.5, -15)
                mfBtn.BackgroundColor3 = THEME_DARK_BG
                mfBtn.TextColor3 = THEME_AKB_BLUE
                mfBtn.Text = "👥"
                mfBtn.Font = Enum.Font.GothamBold
                mfBtn.ZIndex = 3
                Instance.new("UICorner", mfBtn).CornerRadius = UDim.new(0,6)
                bindButton(mfBtn, function() showMutualFriends(p) end)

                local blk = Instance.new("TextButton", row)
                blk.Size = UDim2.new(0, 30, 0, 30)
                blk.Position = UDim2.new(1, -35, 0.5, -15)
                blk.BackgroundColor3 = THEME_DARK_BG
                blk.BackgroundTransparency = 0.5
                blk.Font = Enum.Font.GothamBold
                blk.TextSize = 18
                blk.ZIndex = 3
                Instance.new("UICorner", blk).CornerRadius = UDim.new(0, 6)

                local isBlocked = blockedStatus[p.UserId]
                blk.Text = isBlocked and "🚫" or "🛡️"
                blk.TextColor3 = isBlocked and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(150, 150, 150)

                bindButton(blk, function()
                    pcall(function()
                        if blockedStatus[p.UserId] then StarterGui:SetCore("PromptUnblockPlayer", p)
                        else StarterGui:SetCore("PromptBlockPlayer", p) end
                    end)
                end)
            end
        end
    end
end

UserInputService.InputBegan:Connect(function(i, gp) 
    if gp then return end
    if i.KeyCode == Enum.KeyCode.Z then toggleFreeCam() end
    if i.KeyCode == Enum.KeyCode.X then isEspEnabled = not isEspEnabled; if not isEspEnabled then clearAllESP() end end
end)

RunService.RenderStepped:Connect(function(dt)
    if spectatingPlayer then
        spectateFrame.Visible = true
        spName.Text = spectatingPlayer.DisplayName
        
        if blockedStatus[spectatingPlayer.UserId] then
             spBlockBtn.Text = "🚫 Unblock"
             spBlockBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        else
             spBlockBtn.Text = "🛡️ Block"
             spBlockBtn.TextColor3 = THEME_WHITE
        end
        
        if spectatingPlayer ~= lastSpectatingPlayer then
             lastSpectatingPlayer = spectatingPlayer
             spStatus.Text = "Loading stats..."
             task.spawn(function()
                 local target = spectatingPlayer
                 if not target then return end
                 ensureMyFriends()
                 local mutualCount = 0
                 local serverCount = 0
                 local s, pages = pcall(function() return Players:GetFriendsAsync(target.UserId) end)
                 if not s then
                    if spectatingPlayer == target then spStatus.Text = "Private Profile" end
                    return
                 end
                 local targetFriends = {}
                 while true do
                    for _, item in ipairs(pages:GetCurrentPage()) do table.insert(targetFriends, item) end
                    if pages.IsFinished then break end
                    pages:AdvanceToNextPageAsync()
                 end
                 for _, f in ipairs(targetFriends) do
                     if myFriendsCache and myFriendsCache[f.Id] then mutualCount = mutualCount + 1 end
                     if Players:GetPlayerByUserId(f.Id) then serverCount = serverCount + 1 end
                 end
                 if spectatingPlayer == target then
                     spStatus.Text = "Mutuals: " .. mutualCount .. " | In Server: " .. serverCount
                 end
             end)
        end

        bindButton(spBlockBtn, function()
            pcall(function()
                if blockedStatus[spectatingPlayer.UserId] then StarterGui:SetCore("PromptUnblockPlayer", spectatingPlayer)
                else StarterGui:SetCore("PromptBlockPlayer", spectatingPlayer) end
            end)
        end)

        if spectatingPlayer.Character and spectatingPlayer.Character:FindFirstChild("Humanoid") then
             if camera.CameraSubject ~= spectatingPlayer.Character.Humanoid then
                 camera.CameraSubject = spectatingPlayer.Character.Humanoid
             end
        else
            spectatingPlayer = nil
            lastSpectatingPlayer = nil
            spectateFrame.Visible = false
            if localPlayer.Character then
                camera.CameraSubject = localPlayer.Character:FindFirstChild("Humanoid")
            end
        end
    else
        spectateFrame.Visible = false
        lastSpectatingPlayer = nil
    end

    if isFreeCamEnabled then
        local moveVec = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + Vector3.new(0,0,-1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec + Vector3.new(0,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec + Vector3.new(-1,0,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + Vector3.new(1,0,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveVec = moveVec + Vector3.new(0,-1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveVec = moveVec + Vector3.new(0,1,0) end
        moveVec = moveVec + mobileInput
        
        local currentSpeed = 60
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then currentSpeed = 150 end
        
        local rotCFrame
        if isMobile then
             camRotX = math.clamp(camRotX, math.rad(-89), math.rad(89))
             rotCFrame = CFrame.fromEulerAnglesYXZ(camRotX, camRotY, 0)
        else
             rotCFrame = camera.CFrame.Rotation
        end
        local newPos = camera.CFrame.Position + (rotCFrame * moveVec * currentSpeed * dt)
        camera.CFrame = CFrame.new(newPos) * rotCFrame
    end
    
    if isEspEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p~=localPlayer and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                local bb = nameplates[p]
                if not bb or bb.Adornee ~= head then
                    if bb then bb:Destroy() end
                    bb = Instance.new("BillboardGui", espFolder); bb.Size=UDim2.new(0,100,0,30); bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true; bb.Adornee=head; bb.Name="ESP"
                    
                    local clickBtn = Instance.new("TextButton", bb)
                    clickBtn.Size = UDim2.new(1,0,1,0)
                    clickBtn.BackgroundTransparency = 1
                    clickBtn.Text = ""
                    clickBtn.Active = true 
                    bindButton(clickBtn, function()
                        if p.Character and p.Character:FindFirstChild("Humanoid") then
                            if isFreeCamEnabled then
                                isFreeCamEnabled = false
                                mobileCamFrame.Visible = false
                                freeCamButton.Text = isMobile and "📷 กล้อง: ปิด" or "📷 กล้อง: ปิด (Z)"
                                freeCamButton.UIStroke.Color = THEME_FREECAM
                            end
                            camera.CameraType = Enum.CameraType.Custom
                            camera.CameraSubject = p.Character.Humanoid
                            spectatingPlayer = p
                            if Controls then Controls:Disable() end
                            resetButton.Visible = true 
                        end
                    end)

                    local t = Instance.new("TextLabel", bb); t.Size=UDim2.new(1,0,1,0); t.BackgroundTransparency=1; t.Text=p.DisplayName; t.TextColor3=THEME_MAIN; t.TextStrokeTransparency=0.5; t.Font=Enum.Font.GothamBold; t.TextScaled=true
                    nameplates[p] = bb
                end
                
                local col = COLOR_ENEMY
                if friendStatus[p.UserId] then col = THEME_MAIN end
                if blockedStatus[p.UserId] then col = COLOR_BLOCKED_USER end
                
                local hl = p.Character:FindFirstChild("FantasyHighlight") or Instance.new("Highlight", p.Character)
                hl.Name="FantasyHighlight"; hl.FillColor=col; hl.OutlineColor=col; hl.FillTransparency=0.5
                if nameplates[p] then 
                    local lbl = nameplates[p]:FindFirstChild("TextLabel")
                    if lbl then lbl.TextColor3 = col end
                end
            end
        end
    end
end)

