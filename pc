    task.spawn(function()
        local myFriendsMap = {}
        local s1, myPages = pcall(function() return Players:GetFriendsAsync(localPlayer.UserId) end)
        if s1 then
            local limit = 0
            while true do
                for _, item in ipairs(myPages:GetCurrentPage()) do
                    myFriendsMap[item.Id] = true
                end
                if myPages.IsFinished or limit > 10 then break end
                myPages:AdvanceToNextPageAsync()
                limit = limit + 1
            end
        end

        local mutuals = {}
        local othersInServer = {}

        local targetFriendsAll = {}
        local s2, targetPages = pcall(function() return Players:GetFriendsAsync(targetUserId) end)
        
        if s2 then
             local limit = 0
             while true do
                for _, item in ipairs(targetPages:GetCurrentPage()) do
                    table.insert(targetFriendsAll, item)
                end
                if targetPages.IsFinished or limit > 10 then break end
                targetPages:AdvanceToNextPageAsync()
                limit = limit + 1
            end
        else
             loading.Text = "ไม่สามารถเข้าถึงรายชื่อเพื่อนได้ (Private)"
             loading.TextColor3 = Color3.fromRGB(255, 80, 80)
             return
        end

        for _, f in ipairs(targetFriendsAll) do
            local isMutual = myFriendsMap[f.Id]
            local playerInServer = Players:GetPlayerByUserId(f.Id)

            if isMutual then
                table.insert(mutuals, {
                    Id = f.Id,
                    Username = f.Username,
                    DisplayName = f.DisplayName,
                    IsOnline = f.IsOnline,
                    Instance = playerInServer 
