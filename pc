showMutualFriends = function(targetPlayer)
    if not targetPlayer then return end
    local targetUserId = targetPlayer.UserId

    if mutualFrame.Visible and currentMutualTargetId == targetUserId then
        mutualFrame.Visible = false
        currentMutualTargetId = nil
        return
    end

    currentMutualTargetId = targetUserId
    mutualFrame.Visible = true

    for _, child in pairs(mfList:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextLabel") or child:IsA("TextButton") then child:Destroy() end
    end
    
    local loading = Instance.new("TextLabel")
