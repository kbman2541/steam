switchToNearestPlayer = function(excludedTarget)
    local lastPos = nil
    
    -- [IMPROVED] Use cached position if character is gone (Death/Reset case)
    if excludedTarget and excludedTarget.Character and excludedTarget.Character:FindFirstChild("HumanoidRootPart") then
        lastPos = excludedTarget.Character.HumanoidRootPart.Position
    elseif lastSpectatedPosition then
        lastPos = lastSpectatedPosition
    else
        lastPos = camera.CFrame.Position
    end
    
    local nextTarget = nil
    local shortest = math.huge
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p ~= excludedTarget and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - lastPos).Magnitude
            if dist < shortest then
                shortest = dist
                nextTarget = p
            end
        end
    end
    
    if nextTarget then
        startSpectating(nextTarget)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Auto Switch";
                Text = "Target Lost/LowHP. Switching to: " .. nextTarget.DisplayName;
                Duration = 3;
            })
        end)
        damageCamLockUntil = tick() + 10 
    else
        resetCameraToLocal()
    end
end

