local function ServerHopLogic()
    randomHopBtn.Text = "⏳ กำลังค้นหา..."
    
    local request = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    
    if request then
        task.spawn(function()
            local placeId = game.PlaceId
            local foundServer = nil
            local cursor = ""
            local searchedPages = 0
            local maxPages = 20 
            
            local bestServer = nil
            local minPlayersFound = 999
            
            while searchedPages < maxPages do
                searchedPages = searchedPages + 1
                local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
                
                if cursor and cursor ~= "" then
                    url = url .. "&cursor=" .. cursor
                end
                
                local success, response = pcall(function()
                    return request({Url = url, Method = "GET"})
                end)
                
                if success and response and response.Body then
                    local body = HttpService:JSONDecode(response.Body)
                    if body and body.data then
                        local candidates = {}
                        
                        for _, v in ipairs(body.data) do
                            if type(v) == "table" and v.maxPlayers and v.id ~= game.JobId then
                                local playing = v.playing or 0
                                
                                if playing < minPlayersFound and playing > 0 then
                                    minPlayersFound = playing
                                    bestServer = v.id
                                end
                                
                                if playing < 10 and playing > 0 then
                                    table.insert(candidates, v.id)
                                end
                            end
                        end
                        
                        if #candidates > 0 then
                            randomHopBtn.Text = "เจอห้อง! (" .. #candidates .. ")"
                            task.wait(0.5)
                            foundServer = candidates[math.random(1, #candidates)]
                            break
                        end

                        if body.nextPageCursor then
                            cursor = body.nextPageCursor
                            randomHopBtn.Text = "หาต่อ... (ต่ำสุด: " .. (minPlayersFound == 999 and "-" or minPlayersFound) .. ")"
                            task.wait(0.2) 
                        else
                            break 
                        end
                    end
                else
                    warn("API Error or Rate limit")
                    break
                end
            end
            
            if foundServer then
                randomHopBtn.Text = "🚀 วาร์ป..."
                TeleportService:TeleportToPlaceInstance(placeId, foundServer, localPlayer)
            elseif bestServer then
                randomHopBtn.Text = "⚠️ ไปห้อง " .. minPlayersFound .. " คนแทน"
                task.wait(1)
                TeleportService:TeleportToPlaceInstance(placeId, bestServer, localPlayer)
            else
                randomHopBtn.Text = "❌ ไม่พบห้องเลย"
                task.wait(2)
                randomHopBtn.Text = "🎲 สุ่มห้องคนน้อย (< 10)"
            end
        end)
    else
        randomHopBtn.Text = "❌ Executor ไม่รองรับ"
    end
end
