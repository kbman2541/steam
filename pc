local lastTime = tick()
local joinTime = tick() -- [NEW] ตัวแปรเก็บเวลาตอนสคริปต์เริ่มทำงาน

-- [CRITICAL] เก็บ Connection ใส่ตาราง global เพื่อล้างค่าได้
local renderSteppedConnection = RunService.RenderStepped:Connect(function(dt)
    local currentTime = tick()
    
    -- [NEW] Auto Damage Cam Logic
    if isDamageCamEnabled then
        if spectatingPlayer and spectatingPlayer.Character then
             local sHum = spectatingPlayer.Character:FindFirstChild("Humanoid")
             local sRoot = spectatingPlayer.Character:FindFirstChild("HumanoidRootPart")
             
             -- [NEW] Track position continuously for better switch logic
             if sRoot then
                 lastSpectatedPosition = sRoot.Position
             end
             
             -- Check if dead or health <= 0 (Suicide/Reset) or Low HP
             if sHum and (sHum.Health <= 0 or (sHum.Health / sHum.MaxHealth) < 0.3) then
                 switchToNearestPlayer(spectatingPlayer)
             end
        end

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer and player.Character then
                local hum = player.Character:FindFirstChild("Humanoid")
                if hum then
                    local currentHealth = hum.Health
                    local prevHealth = previousHealths[player.UserId] or currentHealth
                    
                    if currentHealth < prevHealth and currentHealth > 0 then
                        if spectatingPlayer == player then
                            -- Already watching
                        elseif spectatingPlayer == nil then
                            startSpectating(player)
                            damageCamLockUntil = currentTime + 10
                        else
                            if currentTime > damageCamLockUntil then
                                startSpectating(player)
                                damageCamLockUntil = currentTime + 10
                            end
                        end
                    end
                    previousHealths[player.UserId] = currentHealth
                end
            end
        end
    end
    
    if currentTime - lastTime >= 1 then
        local pingValue = math.round(localPlayer:GetNetworkPing() * 1000)
        
        if pingValue < 100 then
            pingLabel.TextColor3 = HEALTH_COLOR_FULL 
        elseif pingValue < 200 then
            pingLabel.TextColor3 = Color3.fromRGB(255, 255, 85) 
        else
            pingLabel.TextColor3 = HEALTH_COLOR_LOW 
        end
        
        pingLabel.Text = "Ping: " .. pingValue .. " ms"
        
        local currentPlayers = #Players:GetPlayers()
        local maxPlayers = Players.MaxPlayers
        playersCountLabel.Text = string.format("Players: %d/%d", currentPlayers, maxPlayers)

        local nonFriendCount = 0
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= localPlayer then
                if not friendStatus[p.UserId] then
                    nonFriendCount = nonFriendCount + 1
                end
            end
        end
        nonFriendsLabel.Text = "Enemies: " .. nonFriendCount
        
        -- [UPDATED] คำนวณเวลาตั้งแต่เริ่มรันสคริปต์ (เวลาที่อยู่ในเซิร์ฟเวอร์นี้)
        local timeInSeconds = math.floor(tick() - joinTime)
        local hours = math.floor(timeInSeconds / 3600)
        local minutes = math.floor((timeInSeconds % 3600) / 60)
        local seconds = timeInSeconds % 60
        timeLabel.Text = string.format("Time: %02d.%02d.%02d", hours, minutes, seconds)

        lastTime = currentTime
    end

    if isFreeCamEnabled then
        local moveVec = Vector3.new()
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + Vector3.new(0, 0, -1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec + Vector3.new(0, 0, 1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec + Vector3.new(-1, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + Vector3.new(1, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveVec = moveVec + Vector3.new(0, -1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveVec = moveVec + Vector3.new(0, 1, 0) end
        
        local currentSpeed = freeCamSpeed
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then currentSpeed = freeCamSpeed * 2.5 end
        
        local rotCFrame = CFrame.fromEulerAnglesYXZ(camRotX, camRotY, 0)
        local newPos = camera.CFrame.Position + (rotCFrame * moveVec * currentSpeed * dt)
        
        camera.CFrame = CFrame.new(newPos) * rotCFrame
    
    elseif spectatingPlayer then
        if not spectatingPlayer.Parent or not spectatingPlayer.Character or not spectatingPlayer.Character:FindFirstChild("Humanoid") then
            -- Note: We handle switch in loop/PlayerRemoving now, but fallback here
            -- Don't reset instantly if we expect a switch
        else
            if isCamLockRotation and spectatingPlayer.Character:FindFirstChild("HumanoidRootPart") then
                 camera.CameraType = Enum.CameraType.Scriptable
                 
                 local hrp = spectatingPlayer.Character.HumanoidRootPart
                 local targetCFrame = hrp.CFrame * CFrame.new(0, 3, 10)
                 
                 -- [FIX] ใช้ค่า Delta Time (dt) เพื่อให้ความสมูทของการแพนกล้องไม่อิงกับเฟรมเรต ป้องกันการกระตุก
                 camera.CFrame = camera.CFrame:Lerp(targetCFrame, 1 - math.exp(-15 * dt))
            else
                 camera.CameraType = Enum.CameraType.Custom
                 if camera.CameraSubject ~= spectatingPlayer.Character.Humanoid then
                     camera.CameraSubject = spectatingPlayer.Character.Humanoid
                 end
            end
        end
    end
    
    if isEspEnabled then
        local camPos = camera.CFrame.Position
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == localPlayer then continue end
            local targetChar = player.Character
            
            if targetChar and targetChar.Parent then
                local head = targetChar:FindFirstChild("Head")
                local rootPart = targetChar:FindFirstChild("HumanoidRootPart")
                local humanoid = targetChar:FindFirstChild("Humanoid")
                
                if head and rootPart then
                    local distance = (rootPart.Position - camPos).Magnitude
                    
                    if distance <= maxEspDistance then
                        local isFriend = friendStatus[player.UserId]
                        local isBlocked = blockedStatus[player.UserId]
                        
                        local espColor = COLOR_ENEMY
                        if isBlocked then
                            espColor = COLOR_BLOCKED_USER
                        elseif isFriend then
                            espColor = THEME_MAIN
                        end

                        local billboard = nameplates[player]
                        
                        if not billboard or billboard.Adornee ~= head then
                            if billboard then billboard:Destroy() end
                            billboard = Instance.new("BillboardGui")
                            billboard.Name = "TextOnlyESP"
                            billboard.Size = UDim2.new(0, 140, 0, 50)
                            billboard.StudsOffset = Vector3.new(0, 3.5, 0)
                            billboard.AlwaysOnTop = true
                            billboard.Active = true 
                            
                            billboard.Parent = espFolder 
                            billboard.Adornee = head 
                            
                            local clickBtn = Instance.new("TextButton")
                            clickBtn.Name = "ClickToSpectate"
                            clickBtn.Size = UDim2.new(1, 0, 1, 0)
                            clickBtn.BackgroundTransparency = 1
                            clickBtn.Text = ""
                            clickBtn.ZIndex = 10 
                            clickBtn.Parent = billboard

                            clickBtn.MouseButton1Click:Connect(function()
                                 startSpectating(player)
                            end)
                            
                            local displayNameLabel = Instance.new("TextLabel", billboard)
                            displayNameLabel.Name = "DisplayLabel"
                            displayNameLabel.Size = UDim2.new(1, 0, 0.4, 0)
                            displayNameLabel.Position = UDim2.new(0, 0, 0, 0)
                            displayNameLabel.BackgroundTransparency = 1
                            displayNameLabel.Font = Enum.Font.GothamMedium
                            displayNameLabel.TextScaled = true 
                            displayNameLabel.TextStrokeTransparency = 0.5
                            displayNameLabel.Text = player.DisplayName
                            
                            local userNameLabel = Instance.new("TextLabel", billboard)
                            userNameLabel.Size = UDim2.new(1, 0, 0.3, 0)
                            userNameLabel.Position = UDim2.new(0, 0, 0.4, 0)
                            userNameLabel.BackgroundTransparency = 1
                            userNameLabel.TextColor3 = THEME_WHITE
                            userNameLabel.Font = Enum.Font.Gotham
                            userNameLabel.TextScaled = true 
                            userNameLabel.TextTransparency = 0.2
                            userNameLabel.TextStrokeTransparency = 0.5
                            userNameLabel.Text = "@" .. player.Name
                            userNameLabel.Parent = billboard
                            
                            local barContainer = Instance.new("Frame")
                            barContainer.Name = "HealthBarContainer"
                            barContainer.Size = UDim2.new(0.8, 0, 0.12, 0)
                            barContainer.Position = UDim2.new(0.1, 0, 0.75, 0)
                            barContainer.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                            barContainer.BorderSizePixel = 0
                            barContainer.Parent = billboard
                            
                            local barStroke = Instance.new("UIStroke", barContainer)
                            barStroke.Color = Color3.fromRGB(0, 0, 0)
                            barStroke.Thickness = 1
                            barStroke.Transparency = 0.5
                            
                            local barCorner = Instance.new("UICorner", barContainer)
                            barCorner.CornerRadius = UDim.new(1, 0)
                            
                            local fill = Instance.new("Frame")
                            fill.Name = "Fill"
                            fill.Size = UDim2.new(1, 0, 1, 0)
                            fill.BackgroundColor3 = HEALTH_COLOR_FULL
                            fill.BorderSizePixel = 0
                            fill.Parent = barContainer
                            
                            local fillCorner = Instance.new("UICorner", fill)
                            fillCorner.CornerRadius = UDim.new(1, 0)
                            
                            nameplates[player] = billboard
                        end
                        
                        -- เปิดการแสดงผลใหม่หากเคยโดนซ่อน
                        billboard.Enabled = true
                        
                        if billboard then
                            local dLabel = billboard:FindFirstChild("DisplayLabel")
                            if dLabel then
                                dLabel.TextColor3 = espColor 
                            end
                        end
                        
                        if billboard and humanoid then
                            local barContainer = billboard:FindFirstChild("HealthBarContainer")
                            if barContainer then
                                local fill = barContainer:FindFirstChild("Fill")
                                if fill then
                                    local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                                    
                                    -- [PERFORMANCE FIX] ไม่ใช้ TweenService รันซ้ำทุกเฟรม ลดการใช้ CPU อย่างมหาศาล
                                    fill.Size = UDim2.new(healthPercent, 0, 1, 0)
                                    fill.BackgroundColor3 = HEALTH_COLOR_LOW:Lerp(HEALTH_COLOR_FULL, healthPercent)
                                end
                            end
                        end
                        
                        local highlight = targetChar:FindFirstChild("FantasyHighlight")
                        if not highlight then
                            highlight = Instance.new("Highlight")
                            highlight.Name = "FantasyHighlight"
                            highlight.FillTransparency = 0.75
                            highlight.OutlineTransparency = 0.2
                            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            highlight.Parent = targetChar
                        end
                        
                        -- เปิดการแสดงผลใหม่หากเคยโดนซ่อน
                        highlight.Enabled = true
                        highlight.FillColor = espColor
                        highlight.OutlineColor = espColor
                    else
                        -- [NEW] ถ้าอยู่ไกลเกิน maxEspDistance ให้ซ่อน ESP ไว้ (ประหยัดสเปค)
                        local billboard = nameplates[player]
                        if billboard then billboard.Enabled = false end
                        
                        local highlight = targetChar:FindFirstChild("FantasyHighlight")
                        if highlight then highlight.Enabled = false end
                    end
                end
            else
                if nameplates[player] then nameplates[player]:Destroy(); nameplates[player] = nil end
            end
        end
    end
end)
